# Build and install elodin.
function install-elodin() {
    case ${1:-all} in
      "py") 
        uv venv --python 3.12 && \
        # This can't be script because it sources a file.
        source .venv/bin/activate && \
        uvx maturin develop --uv --manifest-path=libs/nox-py/Cargo.toml
        ;;
      "editor") cargo install --path apps/elodin --locked;;
      "db") cargo install --path libs/db --locked;;
      "all") install-elodin py && install-elodin db && install-elodin editor;;
      "-h" | "--help")
        echo "usage: install-elodin [py|editor|db|all]"
        return 2;;
      "*")
        echo "error: Invalid argument '$1'" >&2;
        install-elodin --help >&2;
        return 1;;
    esac
}
