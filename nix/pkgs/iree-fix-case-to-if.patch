+// ===----------------------------------------------------------------------===//
+// stablehlo.case op outlining (module-level pass)
+// ===----------------------------------------------------------------------===//
+//
+// Outline whole stablehlo.case ops into private functions so that downstream
+// control-flow legalization and partial dialect conversion never see case/if
+// control flow inside the fused system functions. This prevents the MLIR
+// DialectConversion value-remapping dominance failure.
+static void outlineCaseOps(func::FuncOp f, Operation *symbolTableOp) {
+  if (f.isDeclaration())
+    return;
+
+  SmallVector<mlir::stablehlo::CaseOp> caseOps;
+  f.walk([&](mlir::stablehlo::CaseOp op) { caseOps.push_back(op); });
+  if (caseOps.empty())
+    return;
+
+  unsigned counter = 0;
+  SymbolTable symbolTable(symbolTableOp);
+
+  for (auto caseOp : caseOps) {
+    llvm::SetVector<Value> captures;
+    for (Region &branch : caseOp.getBranches()) {
+      mlir::getUsedValuesDefinedAbove(branch, captures);
+    }
+    captures.insert(caseOp.getIndex());
+
+    SmallVector<Type> argTypes;
+    argTypes.reserve(captures.size());
+    for (Value v : captures) {
+      argTypes.push_back(v.getType());
+    }
+    auto funcTy =
+        FunctionType::get(f.getContext(), argTypes, caseOp.getResultTypes());
+
+    std::string baseName =
+        (f.getSymName() + "_case_" + Twine(counter++)).str();
+    auto outlinedFunc = func::FuncOp::create(caseOp.getLoc(), baseName, funcTy);
+    outlinedFunc.setVisibility(SymbolTable::Visibility::Private);
+    Block *entryBlock = outlinedFunc.addEntryBlock();
+
+    IRMapping mapping;
+    for (auto [capture, arg] :
+         llvm::zip_equal(captures, entryBlock->getArguments())) {
+      mapping.map(capture, arg);
+    }
+
+    OpBuilder outlinedBuilder(entryBlock, entryBlock->begin());
+    Operation *clonedCaseOp =
+        outlinedBuilder.clone(*caseOp.getOperation(), mapping);
+    outlinedBuilder.create<func::ReturnOp>(caseOp.getLoc(),
+                                           clonedCaseOp->getResults());
+
+    symbolTable.insert(outlinedFunc);
+
+    OpBuilder builder(caseOp);
+    SmallVector<Value> callArgs(captures.begin(), captures.end());
+    auto call =
+        builder.create<func::CallOp>(caseOp.getLoc(), outlinedFunc, callArgs);
+    caseOp.replaceAllUsesWith(call.getResults());
+    caseOp.erase();
+  }
+}
+
+void outlineAllCaseOps(ModuleOp moduleOp) {
+  SmallVector<func::FuncOp> funcs;
+  moduleOp.walk([&](func::FuncOp f) { funcs.push_back(f); });
+  for (auto f : funcs)
+    outlineCaseOps(f, moduleOp);
+}
