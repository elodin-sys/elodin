+// ===----------------------------------------------------------------------===//
+// LAPACK solve-pattern rewriter & dead while-loop removal
+// ===----------------------------------------------------------------------===//
+// JAX's jnp.linalg.solve emits: lapack_dgetrf_ffi (LU) -> stablehlo.while
+// (pivot permutation) -> _lu_solve (two dtrsm calls).  IREE's stream scheduler
+// cannot thread external func.call results across while-loop region boundaries,
+// causing a dominance error.  Fix: replace the whole function body with a single
+// lapack_dgetrs_ffi custom_call (the runtime does LU + solve in one shot).
+
+static void rewriteSolvePattern(func::FuncOp f) {
+  if (f.isDeclaration() || f.getNumArguments() != 2)
+    return;
+  bool hasDgetrf = false, hasWhile = false, hasLuSolve = false;
+  f.walk([&](Operation *op) {
+    StringRef name = op->getName().getStringRef();
+    if (name == "stablehlo.custom_call") {
+      if (auto a = op->getAttrOfType<StringAttr>("call_target_name"))
+        if (a.getValue().starts_with("lapack_dgetrf"))
+          hasDgetrf = true;
+    } else if (name == "stablehlo.while") {
+      hasWhile = true;
+    } else if (name == "func.call") {
+      if (auto a = op->getAttrOfType<FlatSymbolRefAttr>("callee"))
+        if (a.getValue().starts_with("_lu_solve"))
+          hasLuSolve = true;
+    }
+  });
+  if (!(hasDgetrf && hasWhile && hasLuSolve))
+    return;
+
+  Block &body = f.getBody().front();
+  Value A = f.getArgument(0);
+  Value B = f.getArgument(1);
+  auto resultType = f.getResultTypes()[0];
+  auto loc = f.getLoc();
+  auto *ctx = f.getContext();
+
+  while (!body.empty())
+    body.back().erase();
+
+  OpBuilder builder(ctx);
+  builder.setInsertionPointToStart(&body);
+
+  auto bTy = dyn_cast<RankedTensorType>(B.getType());
+  bool matrixRHS = bTy && bTy.getRank() == 2;
+
+  Value dgetrsB = B;
+  Type  dgetrsResultType = resultType;
+  if (matrixRHS) {
+    auto sh = bTy.getShape();
+    auto tTy = RankedTensorType::get({sh[1], sh[0]}, bTy.getElementType());
+    OperationState ts(loc, "stablehlo.transpose");
+    ts.addTypes({tTy});
+    ts.addOperands({B});
+    ts.addAttribute("permutation", DenseI64ArrayAttr::get(ctx, {1, 0}));
+    dgetrsB = builder.create(ts)->getResult(0);
+    dgetrsResultType = tTy;
+  }
+
+  auto i32 = RankedTensorType::get({}, IntegerType::get(ctx, 32));
+  OperationState st(loc, "stablehlo.custom_call");
+  st.addTypes({dgetrsResultType, i32});
+  st.addOperands({A, dgetrsB});
+  st.addAttribute("call_target_name",
+                   builder.getStringAttr("lapack_dgetrs_ffi"));
+  st.addAttribute("backend_config", builder.getStringAttr(""));
+  Value result = builder.create(st)->getResult(0);
+
+  if (matrixRHS) {
+    OperationState ts2(loc, "stablehlo.transpose");
+    ts2.addTypes({resultType});
+    ts2.addOperands({result});
+    ts2.addAttribute("permutation", DenseI64ArrayAttr::get(ctx, {1, 0}));
+    result = builder.create(ts2)->getResult(0);
+  }
+
+  func::ReturnOp::create(builder, loc, ValueRange{result});
+}
+
+// Remove stablehlo.while ops whose results are all unused.
+// JAX's slogdet emits dgetrf + while (pivot permutation) but never consumes
+// the while-loop outputs.  Without removal the dead while triggers the same
+// dominance error as solve.
+static void removeDeadWhileLoops(func::FuncOp f) {
+  SmallVector<Operation *> dead;
+  f.walk([&](Operation *op) {
+    if (op->getName().getStringRef() != "stablehlo.while")
+      return;
+    for (Value r : op->getResults())
+      if (!r.use_empty()) return;
+    dead.push_back(op);
+  });
+  for (Operation *op : dead)
+    op->erase();
+}
