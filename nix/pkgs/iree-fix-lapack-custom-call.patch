+// ===----------------------------------------------------------------------===//
+// Scatter-into-constant rewriter
+// ===----------------------------------------------------------------------===//
+// JAX's `.at[idx].set(val)` on a freshly-created array produces:
+//   %c = stablehlo.constant dense<0> : tensor<Nxtype>
+//   %r = stablehlo.scatter(%c, %idx, %val) ...
+// IREE 3.11.0 llvm-cpu cannot distribute the linalg.fill (from the constant)
+// and the scatter write in the same workgroup.  Fix: convert eligible scatters
+// into stablehlo.dynamic_update_slice, which IREE distributes correctly.
+
+struct ScatterIntoConstantRewriter final
+    : OpRewritePattern<mlir::stablehlo::ScatterOp> {
+  using Base::Base;
+
+  LogicalResult matchAndRewrite(mlir::stablehlo::ScatterOp op,
+                                PatternRewriter &rewriter) const final {
+    if (op.getInputs().size() != 1 || op.getUpdates().size() != 1)
+      return failure();
+
+    Value operand = op.getInputs()[0];
+    if (!operand.getDefiningOp() ||
+        operand.getDefiningOp()->getName().getStringRef() != "stablehlo.constant")
+      return failure();
+
+    auto operandTy = dyn_cast<RankedTensorType>(operand.getType());
+    if (!operandTy || operandTy.getRank() != 1)
+      return failure();
+
+    auto dimNumbers = op.getScatterDimensionNumbers();
+    if (dimNumbers.getInsertedWindowDims().size() != 1 ||
+        dimNumbers.getInsertedWindowDims()[0] != 0 ||
+        dimNumbers.getScatterDimsToOperandDims().size() != 1 ||
+        dimNumbers.getScatterDimsToOperandDims()[0] != 0)
+      return failure();
+
+    if (!op.getUniqueIndices())
+      return failure();
+
+    Value scatterIndices = op.getScatterIndices();
+    Value update = op.getUpdates()[0];
+
+    auto updateTy = dyn_cast<RankedTensorType>(update.getType());
+    if (!updateTy || updateTy.getNumElements() != 1)
+      return failure();
+
+    auto loc = op.getLoc();
+
+    auto sliceTy = RankedTensorType::get({1}, operandTy.getElementType());
+    OperationState reshapeSt(loc, "stablehlo.reshape");
+    reshapeSt.addTypes({sliceTy});
+    reshapeSt.addOperands({update});
+    Value reshapedUpdate = rewriter.create(reshapeSt)->getResult(0);
+
+    auto idxTy = dyn_cast<RankedTensorType>(scatterIndices.getType());
+    if (!idxTy)
+      return failure();
+    auto idxScalarTy = RankedTensorType::get({}, idxTy.getElementType());
+    Value idx = scatterIndices;
+
+    if (idxTy.getRank() >= 1) {
+      OperationState reshapeIdx(loc, "stablehlo.reshape");
+      reshapeIdx.addTypes({idxScalarTy});
+      reshapeIdx.addOperands({scatterIndices});
+      idx = rewriter.create(reshapeIdx)->getResult(0);
+    }
+
+    OperationState dusSt(loc, "stablehlo.dynamic_update_slice");
+    dusSt.addTypes({operandTy});
+    dusSt.addOperands({operand, reshapedUpdate, idx});
+    Operation *dus = rewriter.create(dusSt);
+
+    rewriter.replaceOp(op, dus->getResults());
+    return success();
+  }
+};
+
+// ===----------------------------------------------------------------------===//
+// LAPACK FFI custom_call lowering
+// ===----------------------------------------------------------------------===//
+
+struct LapackCustomCallRewriter final
+    : OpRewritePattern<mlir::stablehlo::CustomCallOp> {
+  using Base::Base;
+
+  LogicalResult matchAndRewrite(mlir::stablehlo::CustomCallOp op,
+                                PatternRewriter &rewriter) const final {
+    StringRef target = op.getCallTargetName();
+    if (!target.starts_with("lapack_"))
+      return failure();
+    StringRef lapackName = target.drop_front(7);
+    if (lapackName.ends_with("_ffi"))
+      lapackName = lapackName.drop_back(4);
+    std::string suffix;
+    for (auto ty : op.getOperandTypes()) {
+      if (auto shaped = dyn_cast<ShapedType>(ty)) {
+        for (int64_t dim : shaped.getShape())
+          suffix += "_" + std::to_string(dim);
+      }
+    }
+    std::string funcName = ("elodin_lapack." + lapackName + suffix).str();
+    auto funcType = rewriter.getFunctionType(
+        op.getOperandTypes(), op.getResultTypes());
+    auto moduleOp = op->getParentOfType<ModuleOp>();
+    if (moduleOp && !moduleOp.lookupSymbol(funcName)) {
+      OpBuilder moduleBuilder(moduleOp.getContext());
+      moduleBuilder.setInsertionPointToStart(moduleOp.getBody());
+      auto funcOp = func::FuncOp::create(
+          moduleBuilder, op.getLoc(), funcName, funcType);
+      funcOp.setVisibility(SymbolTable::Visibility::Private);
+    }
+    rewriter.replaceOpWithNewOp<func::CallOp>(
+        op, funcName, op.getResultTypes(), op.getOperands());
+    return success();
+  }
+};
