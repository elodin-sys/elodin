--- a/compiler/plugins/input/StableHLO/Conversion/Passes.cpp
+++ b/compiler/plugins/input/StableHLO/Conversion/Passes.cpp
@@ -7,6 +7,7 @@
 #include "compiler/plugins/input/StableHLO/Conversion/Passes.h"
 
 #include "compiler/plugins/input/StableHLO/Conversion/Preprocessing/Passes.h"
+#include "stablehlo/dialect/StablehloOps.h"
 #include "iree/compiler/Dialect/Util/Transforms/Passes.h"
 #include "iree/compiler/InputConversion/Common/Passes.h"
 #include "mlir/Conversion/ReconcileUnrealizedCasts/ReconcileUnrealizedCasts.h"
@@ -90,3 +91,61 @@
  }, "elodin-lower-scf-if-to-cf"));
+
+  // Elodin: hoist stablehlo.convert past stablehlo.reshape to prevent
+  // ConvertStableHloToIreeInputDialects from creating shape mismatches.
+  //
+  // When a reshape reduces rank (tensor<1xT> -> tensor<T>) and is followed
+  // by a convert that changes element type (tensor<T> -> tensor<U>), the
+  // partial conversion in ConvertStableHloToIreeInputDialects remaps values
+  // so that the convert fires on the pre-reshape input, producing
+  // tensor<1xU> instead of tensor<U>.  Downstream stablehlo.compare ops
+  // then have mismatched shapes (tensor<1xU> vs tensor<U>).
+  //
+  // Fix: swap the order to (convert, then reshape) so that the convert
+  // preserves shape and the reshape only changes shape.
+  passManager.addPass(createModulePass([](ModuleOp moduleOp) {
+    moduleOp.walk([](func::FuncOp funcOp) {
+      if (funcOp.isDeclaration())
+        return;
+      SmallVector<mlir::stablehlo::ConvertOp> converts;
+      funcOp.walk([&](mlir::stablehlo::ConvertOp cvt) {
+        auto reshapeOp =
+            cvt.getOperand().getDefiningOp<mlir::stablehlo::ReshapeOp>();
+        if (!reshapeOp)
+          return;
+        auto inTy = mlir::dyn_cast<RankedTensorType>(
+            reshapeOp.getOperand().getType());
+        auto midTy = mlir::dyn_cast<RankedTensorType>(reshapeOp.getType());
+        auto outTy = mlir::dyn_cast<RankedTensorType>(cvt.getType());
+        if (!inTy || !midTy || !outTy)
+          return;
+        if (inTy.getElementType() == outTy.getElementType())
+          return;
+        if (midTy.getRank() >= inTy.getRank())
+          return;
+        converts.push_back(cvt);
+      });
+      for (auto cvt : converts) {
+        auto reshapeOp =
+            cvt.getOperand().getDefiningOp<mlir::stablehlo::ReshapeOp>();
+        auto inTy = mlir::cast<RankedTensorType>(
+            reshapeOp.getOperand().getType());
+        auto outTy = mlir::cast<RankedTensorType>(cvt.getType());
+        auto convertedTy = RankedTensorType::get(
+            inTy.getShape(), outTy.getElementType());
+
+        OpBuilder builder(cvt);
+        auto loc = cvt.getLoc();
+        auto newConvert = builder.create<mlir::stablehlo::ConvertOp>(
+            loc, convertedTy, reshapeOp.getOperand());
+        auto newReshape = builder.create<mlir::stablehlo::ReshapeOp>(
+            loc, outTy, newConvert);
+        cvt.replaceAllUsesWith(newReshape.getResult());
+        cvt.erase();
+        if (reshapeOp->use_empty())
+          reshapeOp.erase();
+      }
+    });
+  }, "elodin-hoist-convert-past-reshape"));
+
  passManager.addPass(createConvertStableHloToIreeInputDialects());
  passManager.addPass(createReconcileUnrealizedCastsPass());
