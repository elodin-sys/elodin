+#include "mlir/Transforms/DialectConversion.h"
 #include "mlir/Dialect/Func/IR/FuncOps.h"
@@ -89,4 +92,25 @@
       mlir::stablehlo::createChloLegalizeToStablehloPass());
+  passManager.addPass(createModulePass([](ModuleOp moduleOp) {
+    MLIRContext *ctx = moduleOp.getContext();
+    moduleOp.walk([&](func::FuncOp funcOp) {
+      if (funcOp.isDeclaration())
+        return;
+      bool hasIf = false;
+      funcOp.walk([&](scf::IfOp) { hasIf = true; });
+      if (!hasIf)
+        return;
+
+      RewritePatternSet patterns(ctx);
+      mlir::populateSCFToControlFlowConversionPatterns(patterns);
+
+      ConversionTarget target(*ctx);
+      target.addIllegalOp<scf::IfOp>();
+      target.addLegalOp<cf::BranchOp, cf::CondBranchOp>();
+      target.markUnknownOpDynamicallyLegal([](Operation *) { return true; });
+
+      (void)applyPartialConversion(funcOp, target, std::move(patterns));
+    });
+  }, "elodin-lower-scf-if-to-cf"));
   passManager.addPass(createConvertStableHloToIreeInputDialects());
   passManager.addPass(createReconcileUnrealizedCastsPass());
 
