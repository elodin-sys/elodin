 namespace mlir::iree_compiler::stablehlo {
 
+
+// ===----------------------------------------------------------------------===//
+// Large-constant promotion
+// ===----------------------------------------------------------------------===//
+
+static constexpr int64_t kDefaultPromoteThresholdBytes = 1 * 1024 * 1024;
+
+static int64_t getPromoteThreshold() {
+  if (const char *env = std::getenv("ELODIN_IREE_CONSTANT_PROMOTE_THRESHOLD")) {
+    int64_t val = std::atoll(env);
+    if (val >= 0) return val;
+  }
+  return kDefaultPromoteThresholdBytes;
+}
+
+static llvm::DenseMap<StringRef, SmallVector<func::CallOp>>
+buildCallerMap(ModuleOp moduleOp) {
+  llvm::DenseMap<StringRef, SmallVector<func::CallOp>> callerMap;
+  moduleOp.walk([&](func::CallOp callOp) {
+    callerMap[callOp.getCallee()].push_back(callOp);
+  });
+  return callerMap;
+}
+
+static SmallVector<func::FuncOp>
+findCallChain(func::FuncOp mainFunc, func::FuncOp targetFunc,
+              ModuleOp moduleOp,
+              const llvm::DenseMap<StringRef, SmallVector<func::CallOp>> &callerMap) {
+  if (mainFunc == targetFunc)
+    return {mainFunc};
+  llvm::DenseMap<func::FuncOp, func::FuncOp> parent;
+  SmallVector<func::FuncOp> queue;
+  queue.push_back(targetFunc);
+  parent[targetFunc] = nullptr;
+  while (!queue.empty()) {
+    func::FuncOp current = queue.pop_back_val();
+    StringRef currentName = current.getSymName();
+    auto it = callerMap.find(currentName);
+    if (it == callerMap.end())
+      continue;
+    for (func::CallOp callOp : it->second) {
+      auto callerFunc = callOp->getParentOfType<func::FuncOp>();
+      if (!callerFunc || parent.count(callerFunc))
+        continue;
+      parent[callerFunc] = current;
+      if (callerFunc == mainFunc) {
+        SmallVector<func::FuncOp> chain;
+        func::FuncOp node = mainFunc;
+        while (node) {
+          chain.push_back(node);
+          auto pIt = parent.find(node);
+          node = (pIt != parent.end()) ? pIt->second : nullptr;
+        }
+        return chain;
+      }
+      queue.push_back(callerFunc);
+    }
+  }
+  return {};
+}
+
+static void promoteConstant(
+    mlir::stablehlo::ConstantOp constOp,
+    func::FuncOp mainFunc,
+    ModuleOp moduleOp,
+    const llvm::DenseMap<StringRef, SmallVector<func::CallOp>> &callerMap) {
+  auto containingFunc = constOp->getParentOfType<func::FuncOp>();
+  if (!containingFunc) return;
+  auto chain = findCallChain(mainFunc, containingFunc, moduleOp, callerMap);
+  if (chain.empty()) return;
+  Type constType = constOp.getResult().getType();
+  Location loc = constOp.getLoc();
+  MLIRContext *ctx = moduleOp.getContext();
+  {
+    auto funcType = containingFunc.getFunctionType();
+    SmallVector<Type> newInputs(funcType.getInputs());
+    newInputs.push_back(constType);
+    containingFunc.setFunctionType(
+        FunctionType::get(ctx, newInputs, funcType.getResults()));
+    BlockArgument newArg =
+        containingFunc.getBody().front().addArgument(constType, loc);
+    constOp.getResult().replaceAllUsesWith(newArg);
+    constOp.erase();
+  }
+  for (int i = chain.size() - 2; i >= 0; --i) {
+    func::FuncOp callerFunc = chain[i];
+    func::FuncOp calleeFunc = chain[i + 1];
+    auto callerType = callerFunc.getFunctionType();
+    SmallVector<Type> newInputs(callerType.getInputs());
+    newInputs.push_back(constType);
+    callerFunc.setFunctionType(
+        FunctionType::get(ctx, newInputs, callerType.getResults()));
+    BlockArgument newCallerArg =
+        callerFunc.getBody().front().addArgument(constType, loc);
+    StringRef calleeName = calleeFunc.getSymName();
+    callerFunc.walk([&](func::CallOp callOp) {
+      if (callOp.getCallee() == calleeName) {
+        callOp.getOperandsMutable().append(newCallerArg);
+      }
+    });
+  }
+}
+
+void promoteLargeConstants(ModuleOp moduleOp) {
+  int64_t threshold = getPromoteThreshold();
+  if (threshold == 0) return;
+  func::FuncOp mainFunc;
+  moduleOp.walk([&](func::FuncOp f) {
+    if (f.isPublic() && f.getSymName() == "main")
+      mainFunc = f;
+  });
+  if (!mainFunc) return;
+  SmallVector<mlir::stablehlo::ConstantOp> largeConstants;
+  moduleOp.walk([&](mlir::stablehlo::ConstantOp op) {
+    auto attr = op.getValue();
+    if (auto dense = dyn_cast<DenseElementsAttr>(attr)) {
+      if ((int64_t)dense.getRawData().size() > threshold)
+        largeConstants.push_back(op);
+    } else if (auto res = dyn_cast<DenseResourceElementsAttr>(attr)) {
+      auto blob = res.getRawHandle().getBlob();
+      if (blob && (int64_t)blob->getData().size() > threshold)
+        largeConstants.push_back(op);
+    }
+  });
+  if (largeConstants.empty()) return;
+  auto callerMap = buildCallerMap(moduleOp);
+  int promoted = 0;
+  int64_t totalBytes = 0;
+  for (auto constOp : largeConstants) {
+    int64_t bytes = 0;
+    if (auto dense = dyn_cast<DenseElementsAttr>(constOp.getValue()))
+      bytes = dense.getRawData().size();
+    else if (auto res = dyn_cast<DenseResourceElementsAttr>(constOp.getValue())) {
+      auto blob = res.getRawHandle().getBlob();
+      if (blob) bytes = blob->getData().size();
+    }
+    promoteConstant(constOp, mainFunc, moduleOp, callerMap);
+    ++promoted;
+    totalBytes += bytes;
+  }
+  if (promoted > 0) {
+    llvm::errs() << "[elodin] promoted " << promoted << " large constant(s) ("
+                 << (totalBytes / (1024 * 1024)) << " MB) to runtime buffers\n";
+  }
+}
