+inline std::unique_ptr<OperationPass<ModuleOp>>
+createModulePass(std::function<void(ModuleOp)> body,
+                 StringRef name = "elodin-promote-large-constants") {
+  struct LambdaPass : public PassWrapper<LambdaPass, OperationPass<ModuleOp>> {
+    std::function<void(ModuleOp)> fn;
+    StringRef passName;
+    LambdaPass(std::function<void(ModuleOp)> f, StringRef n)
+        : fn(std::move(f)), passName(n) {}
+    StringRef getArgument() const override { return passName; }
+    StringRef getDescription() const override {
+      return "Elodin: promote large constants to function parameters";
+    }
+    void runOnOperation() override { fn(getOperation()); }
+  };
+  return std::make_unique<LambdaPass>(std::move(body), name);
+}
