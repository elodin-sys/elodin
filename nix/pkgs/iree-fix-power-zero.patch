+// ===----------------------------------------------------------------------===//
+// IEEE 754 power(x, 0) = 1 fixup
+// ===----------------------------------------------------------------------===//
+//
+// WORKAROUND for broken math.powf expansion in LLVM MLIR (bundled with IREE
+// 3.11.0, llvm-project commit 66395ad94c3283d938a2957e7c7b439711764680).
+//
+// Problem:
+//   stablehlo.power lowers to math.powf, which LLVM's ExpandPatterns.cpp
+//   expands as exp(y * log(x)).  When x=0, y=0: log(0)=-inf, 0*-inf=NaN
+//   (IEEE 754 indeterminate), exp(NaN)=NaN.  IEEE 754 defines pow(x,+-0)=1
+//   for ALL x, including 0, NaN, and inf.
+//
+// Impact:
+//   Any JAX code doing jnp.power(0.0, 0.0) produces NaN on IREE but 1.0 on
+//   JAX-CPU.  Discovered via customer FT16 sim where a power-law noise model
+//   uses exponent=0 (constant noise) with speed=0 (rocket on pad at t=0).
+//   The NaN propagates through sqrt(covariance) into sensor noise samples,
+//   then into all physics state via EKF feedback.
+//
+// Fix:
+//   Intercept every stablehlo.PowOp before it reaches the math.powf lowering
+//   and wrap the result with: select(y == 0, 1.0, power(x, y)).
+//   When y==0 the select short-circuits the broken exp path.
+//
+// When to remove:
+//   This patch can be removed when IREE upgrades its bundled LLVM to include
+//   the upstream fixes for math.powf edge cases:
+//     - https://github.com/llvm/llvm-project/pull/124402
+//     - https://github.com/llvm/llvm-project/pull/126338
+//   At that point, math.powf will natively handle pow(0,0)=1 and this
+//   select-guard becomes redundant.
+
+static void fixupPowerZeroExponent(func::FuncOp f) {
+  if (f.isDeclaration())
+    return;
+
+  SmallVector<mlir::stablehlo::PowOp> powOps;
+  f.walk([&](mlir::stablehlo::PowOp op) { powOps.push_back(op); });
+  if (powOps.empty())
+    return;
+
+  auto *ctx = f.getContext();
+  OpBuilder builder(ctx);
+
+  for (auto op : powOps) {
+    auto resultType = dyn_cast<RankedTensorType>(op.getType());
+    if (!resultType)
+      continue;
+    auto elemTy = resultType.getElementType();
+    if (!isa<FloatType>(elemTy))
+      continue;
+
+    builder.setInsertionPointAfter(op);
+    auto loc = op.getLoc();
+    Value rhs = op.getRhs();
+
+    auto zeroAttr = builder.getZeroAttr(resultType);
+    Value zero = builder.create<mlir::stablehlo::ConstantOp>(loc, zeroAttr);
+
+    auto oneAttr = DenseElementsAttr::get(
+        resultType, builder.getFloatAttr(elemTy, 1.0));
+    Value one = builder.create<mlir::stablehlo::ConstantOp>(loc, oneAttr);
+
+    Value yIsZero = builder.create<mlir::stablehlo::CompareOp>(
+        loc, rhs, zero, mlir::stablehlo::ComparisonDirection::EQ);
+
+    Value safeResult = builder.create<mlir::stablehlo::SelectOp>(
+        loc, yIsZero, one, op.getResult());
+
+    op.getResult().replaceAllUsesExcept(safeResult, safeResult.getDefiningOp());
+  }
+}
+
