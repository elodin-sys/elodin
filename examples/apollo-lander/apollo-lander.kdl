coordinate frame=ENU
theme mode=dark scheme=default
timeline
hsplit {
    viewport name="Tranquility Base" near=1.0 far=200000.0 pos="lander.world_pos.translate_world(10.0, 10.0, 4.0)" look_at=lander.world_pos hdr=#true show_grid=#false share=0.463842 {
        bloom preset="old_school" intensity=0.45 threshold=0.65 threshold_softness=0.15 
        // bloom preset="natural" intensity=0.25
    }
    vsplit share=0.536157 {
        hsplit {
            graph "lander.altitude[0], lander_truth.altitude[0], lander_truth.slant_range[0]" name="Altitude vs real + radar slant (m)" {
                color 106 155 165
                color 114 87 179
                color 196 160 70
            }
            graph "lander_truth.vertical_speed[0], lander.vertical_speed[0]" name="Descent rate (m/s)" {
                color 106 155 165
                color 114 87 179
            }
        }
        hsplit {
            graph "lander.horizontal_speed[0], lander_truth.horizontal_speed[0]" name="Horizontal speed vs reconstructed (m/s)" {
                color 106 155 165
                color 114 87 179
            }
            graph "lander.pitch[0], lander_truth.pitch[0]" name="Pitch vs gimbal-derived truth (deg)" {
                color 106 155 165
                color 114 87 179
            }
        }
        hsplit {
            graph "lander.throttle_cmd[0], lander.throttle[0]" name="DPS throttle" {
                color 106 155 165
                color 114 87 179
            }
            graph "lander.propellant[0], lander.rcs_propellant[0]" name="Propellant remaining (kg)" {
                color 106 155 165
                color 114 87 179
            }
        }
    }
}
object_3d surface.world_pos frame=ENU {
    glb path=apollo11-landing-site.glb scale=117.416801 rotate="(-90, 0, 0)" emissivity=0.1 glow=0.5
}
// All thruster exhaust is declared here in KDL and driven by EQL viz channels.
// DPS: vector intensity (direction + magnitude from lander.main_thrust_viz).
// RCS: 16 cold-gas jets, scalar intensity from lander.rcs_thruster_viz[i].
// RCS index order must match RCS_THRUSTER_AXIS / RCS_THRUSTER_SIGN in rcs_geometry.py.
// Positions are in the visible object frame after the GLB translate below, tuned to
// the Apollo LM nozzle band rather than the old oversized idealized radius.
object_3d lander.world_pos frame=ENU {
    glb path=apollo-lunar-module.glb translate="(0, -2.5, 0)"
    thruster name="DPS" effect="plume" body_frame=#true position="(0, -0.55, 0)" intensity=lander.main_thrust_viz
    thruster name="rcs_0" effect="cold_gas" body_frame=#true position="(1.41, 0.90, 1.26)" direction="(-1, 0, 0)" intensity="lander.rcs_thruster_viz[0]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_1" effect="cold_gas" body_frame=#true position="(1.32, 0.87, -1.36)" direction="(-1, 0, 0)" intensity="lander.rcs_thruster_viz[1]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_2" effect="cold_gas" body_frame=#true position="(1.25, 1.09, 0)" direction="(0, -1, 0)" intensity="lander.rcs_thruster_viz[2]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_3" effect="cold_gas" body_frame=#true position="(1.25, 0.68, 0)" direction="(0, 1, 0)" intensity="lander.rcs_thruster_viz[3]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_4" effect="cold_gas" body_frame=#true position="(-1.36, 0.92, 1.28)" direction="(1, 0, 0)" intensity="lander.rcs_thruster_viz[4]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_5" effect="cold_gas" body_frame=#true position="(-1.29, 0.85, -1.36)" direction="(1, 0, 0)" intensity="lander.rcs_thruster_viz[5]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_6" effect="cold_gas" body_frame=#true position="(-1.21, 1.09, 0)" direction="(0, -1, 0)" intensity="lander.rcs_thruster_viz[6]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_7" effect="cold_gas" body_frame=#true position="(-1.21, 0.68, 0)" direction="(0, 1, 0)" intensity="lander.rcs_thruster_viz[7]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_8" effect="cold_gas" body_frame=#true position="(1.32, 0.91, 1.37)" direction="(0, 0, -1)" intensity="lander.rcs_thruster_viz[8]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_9" effect="cold_gas" body_frame=#true position="(-1.23, 0.91, 1.36)" direction="(0, 0, -1)" intensity="lander.rcs_thruster_viz[9]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_10" effect="cold_gas" body_frame=#true position="(0, 1.06, 1.24)" direction="(0, -1, 0)" intensity="lander.rcs_thruster_viz[10]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_11" effect="cold_gas" body_frame=#true position="(0, 0.77, 1.24)" direction="(0, 1, 0)" intensity="lander.rcs_thruster_viz[11]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_12" effect="cold_gas" body_frame=#true position="(1.09, 0.87, -1.44)" direction="(0, 0, 1)" intensity="lander.rcs_thruster_viz[12]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_13" effect="cold_gas" body_frame=#true position="(-1.06, 0.86, -1.44)" direction="(0, 0, 1)" intensity="lander.rcs_thruster_viz[13]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_14" effect="cold_gas" body_frame=#true position="(0, 1.13, -1.37)" direction="(0, -1, 0)" intensity="lander.rcs_thruster_viz[14]" emission_rate=140.0 cutoff=0.006
    thruster name="rcs_15" effect="cold_gas" body_frame=#true position="(0, 0.60, -1.37)" direction="(0, 1, 0)" intensity="lander.rcs_thruster_viz[15]" emission_rate=140.0 cutoff=0.006
}
// Moon sphere as the curved horizon backdrop. With this rotation/scale the
// LRO mesh surface directly under the site sits ~1,725,022 m above the sphere
// center; seat it ~1.2 km below z=0 so it stays under the landing-site tile's
// 60x-exaggerated valleys (deepest ~-1,116 m) and never pokes through.
object_3d "(0,0,0,1, 0,0,-1726250)" frame=ENU {
    glb path=moon.glb rotate="(25.32, 21.2, 79.59)" scale=1798000.0 emissivity=0.2 glow=1.0
}
line_3d lander.world_pos frame=ENU {
    color 20 97 209 220
}
line_3d lander_truth.world_pos frame=ENU {
    color 0 255 0 220
}
vector_arrow lander.main_thrust_viz origin=lander.world_pos scale=2.0 name="DPS thrust" body_frame=#true frame=ENU {
    color 255 128 0 220
}
vector_arrow lander.rcs_torque_viz origin=lander.world_pos scale=1.5 name="RCS torque" body_frame=#true frame=ENU {
    color white
}
window screen=0 {
    rect 3 3 97 97
}
